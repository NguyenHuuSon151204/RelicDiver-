  m_Script: {fileID: 11500000, guid: e1fa6e7475b5db645b383f0b31df8a81, type: 3}
  m_Name: DialogLv4
  m_EditorClassIdentifier: 
  lines:
  - characterName: "Th\u1EE3 l\u1EB7n"
    content: The oxygen extraction from the moss worked better than expected. My
      lungs feel rejuvenated.
    characterIcon: {fileID: 0}
    isRightSide: 0
  - characterName: "Ti\u1EBFn s\u0129"
    content: "Ancient technology never ceases to amaze. Now for the real challenge:
      The Ruins of Atlan. You\u2019ll be taking the submarine in."
    characterIcon: {fileID: 0}
    isRightSide: 1
  - characterName: "Th\u1EE3 l\u1EB7n"
    content: A massive ruin... Sonar is reporting large shadows moving around the
      perimeter.
    characterIcon: {fileID: 0}
    isRightSide: 0
  - characterName: "Ti\u1EBFn s\u0129"
    content: 'Ignore them. Focus on the 4 pottery shards and stone statues. And remember:
      don''t leave your lights on for too long if you don''t want to become ''prey''.'
    characterIcon: {fileID: 0}
    isRightSide: 1
